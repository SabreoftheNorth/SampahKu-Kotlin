<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- THUMBNAIL INDICATOR -->
        <!-- TODO: Put thumbnail png here (e.g., thumb_video_large.png) -->
        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_sampahku"
            android:background="@color/gray_light"
            android:contentDescription="Thumbnail Video Besar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_judul_edukasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cara Mendaur Ulang Sampah Organik"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

            <TextView
                android:id="@+id/tv_desc_edukasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Pelajari bagaimana cara mengolah sampah organik menjadi pupuk kompos yang berguna untuk tanaman anda."
                android:textColor="@color/gray_text"
                android:textSize="14sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_regular" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tonton_video"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"
                android:text="@string/tonton_video"
                android:textColor="@color/green_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_play_circle"
                app:iconGravity="end"
                app:iconTint="@color/green_primary"
                android:padding="0dp"
                android:fontFamily="@font/plus_jakarta_sans_bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
