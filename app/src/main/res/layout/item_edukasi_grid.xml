<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- THUMBNAIL INDICATOR -->
        <!-- TODO: Put thumbnail png here (e.g., thumb_video_grid.png) -->
        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_sampahku"
            android:background="@color/gray_light"
            android:contentDescription="Thumbnail Video" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_judul_edukasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Judul Video"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tonton_video"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginTop="4dp"
                android:text="@string/tonton_video"
                android:textColor="@color/green_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_play_circle"
                app:iconGravity="end"
                app:iconSize="14dp"
                app:iconTint="@color/green_primary"
                android:padding="0dp"
                android:fontFamily="@font/plus_jakarta_sans_bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
