<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_reward_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/logo_gopay"
            android:scaleType="centerInside"
            android:background="@color/gray_light"
            android:padding="12dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
            android:contentDescription="Logo merchant" />

        <TextView
            android:id="@+id/tv_reward_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Gopay Coins"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="@font/plus_jakarta_sans_bold" />

        <TextView
            android:id="@+id/tv_reward_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="100 Poin"
            android:textColor="@color/green_primary"
            android:textSize="12sp"
            android:fontFamily="@font/plus_jakarta_sans_semibold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tukar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:text="Tukar"
            android:textColor="@color/green_dark"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/green_card"
            app:cornerRadius="18dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:fontFamily="@font/plus_jakarta_sans_bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
