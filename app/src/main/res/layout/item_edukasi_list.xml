<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray_divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Optional thumbnail for list if desired, keeping it compact for now -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_judul_edukasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cara Memilah Sampah"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

            <TextView
                android:id="@+id/tv_desc_edukasi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tips memilah sampah"
                android:textColor="@color/gray_text"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_regular" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tonton_video"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tonton_video"
            android:textColor="@color/green_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_play_circle"
            app:iconGravity="end"
            app:iconTint="@color/green_primary"
            android:padding="0dp"
            android:fontFamily="@font/plus_jakarta_sans_bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
